# ============================================
# TaskHive Environment Variables (Template)
# ============================================
# Copy this file to .env and fill in real values.
# Never commit your actual .env to version control.
#
# FOR RAILWAY DEPLOYMENT: set all of these in
# Railway Dashboard → Your Service → Variables

# ---- Django Core ----
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-app-name.railway.app
SITE_URL=https://your-app-name.railway.app

# ---- CSRF (Railway domain, comma-separated if multiple) ----
CSRF_TRUSTED_ORIGINS=https://your-app-name.railway.app

# ---- Database ----
# On Railway: added automatically when you attach a Postgres plugin.
# Do NOT set this locally — local dev uses SQLite automatically.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Email (Gmail SMTP) ----
# For Gmail, use an App Password (not your regular password).
# https://support.google.com/accounts/answer/185833
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# ---- Google OAuth ----
# Get these from https://console.cloud.google.com/apis/credentials
# Add your Railway URL as an Authorized redirect URI:
#   https://your-app-name.railway.app/auth/google/callback/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
